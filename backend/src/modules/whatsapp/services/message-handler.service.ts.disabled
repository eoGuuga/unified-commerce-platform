import { Injectable, Logger } from '@nestjs/common';
import { CartService, Cart } from './cart.service';
import { WhatsAppErrorHandler, ErrorContext } from './error-handler.service';
import { WhatsAppAnalyticsService, MessageMetrics } from './analytics.service';
import { LLMRouterService, RouterDecision } from './llm-router.service';
import { ActionExecutorService, ExecutionContext, ExecutionResult } from './action-executor.service';
import { BotConfigService, BotConfig } from './bot-config.service';
import { ConversationService } from './conversation.service';
import { ProductsService } from '../../products/products.service';

export interface IncomingMessage {
  from: string;
  body: string;
  timestamp: string;
  tenantId: string;
  messageId?: string;
  messageType?: 'text' | 'image' | 'document' | 'button' | 'audio';
  mediaUrl?: string;
  metadata?: Record<string, unknown>;
}

export interface OutgoingMessage {
  to: string;
  body: string;
  messageType?: 'text' | 'image' | 'document' | 'button';
  mediaUrl?: string;
}

export type MessageHandlerResponse =
  | string
  | { kind: 'interactive_list'; previewText: string; list: any };

interface HandlerConfig {
  enableCart: boolean;
  enableAnalytics: boolean;
  enableRetry: boolean;
  maxProcessingTimeMs: number;
}

const DEFAULT_CONFIG: HandlerConfig = {
  enableCart: true,
  enableAnalytics: true,
  enableRetry: true,
  maxProcessingTimeMs: 10000,
};

@Injectable()
export class MessageHandlerService {
  private readonly logger = new Logger(MessageHandlerService.name);
  private readonly config: HandlerConfig;

  constructor(
    private readonly cartService: CartService,
    private readonly errorHandler: WhatsAppErrorHandler,
    private readonly analytics: WhatsAppAnalyticsService,
    private readonly llmRouter: LLMRouterService,
    private readonly actionExecutor: ActionExecutorService,
    private readonly botConfig: BotConfigService,
    private readonly conversationService: ConversationService,
    private readonly productsService: ProductsService,
  ) {
    this.config = DEFAULT_CONFIG;
  }

  /**
   * Processa mensagem de entrada e retorna resposta
   */
  async handleMessage(message: IncomingMessage): Promise<MessageHandlerResponse> {
    const startTime = Date.now();
    let success = false;
    let errorMessage: string | undefined;

    try {
      // 1. Validar mensagem
      this.validateMessage(message);

      // 2. Obter configuração do bot
      const botConfig = await this.botConfig.getConfig(message.tenantId);

      // 3. Buscar ou criar conversa
      const conversation = await this.conversationService.getOrCreateConversation(
        message.tenantId,
        message.from,
      );

      // 4. Salvar mensagem de entrada
      await this.conversationService.saveMessage(
        conversation.id,
        'inbound',
        message.body,
        message.messageType || 'text',
        { messageId: message.messageId },
      );

      // 5. Roteamento (classificação de intent)
      const routingContext = await this.buildRoutingContext(message, conversation, botConfig);
      const decision = await this.llmRouter.route(routingContext);

      this.logger.log('Message routed', {
        intent: decision.action,
        confidence: decision.confidence,
        customer: message.from,
      });

      // 6. Executar ação
      const executionContext: ExecutionContext = {
        tenantId: message.tenantId,
        conversation: conversation as any,
        botConfig,
        message: message.body,
        customerName: conversation.customer_name || undefined,
      };

      const result = await this.actionExecutor.execute(decision, executionContext);

      // 7. Processar resposta
      let response: string;

      if (result.response) {
        response = result.response;
      } else if (result.stateTransition) {
        // Estado mudou, precisa de resposta específica
        response = await this.generateStateResponse(
          message,
          result.stateTransition,
          botConfig,
          conversation,
        );
      } else {
        response = await this.generateDefaultResponse(message, decision, botConfig);
      }

      // 8. Salvar mensagem de saída
      await this.conversationService.saveMessage(
        conversation.id,
        'outbound',
        response,
        'text',
      );

      // 9. Atualizar analytics
      if (this.config.enableAnalytics) {
        await this.trackMetrics({
          tenantId: message.tenantId,
          timestamp: new Date(),
          messageId: message.messageId || '',
          customerPhone: message.from,
          direction: 'inbound',
          messageType: message.messageType || 'text',
          processingTimeMs: Date.now() - startTime,
          intent: decision.action,
          success: true,
        });
      }

      success = true;
      return response;

    } catch (error) {
      const err = error instanceof Error ? error : new Error(String(error));
      errorMessage = err.message;

      // Tratar erro com error handler
      const errorContext: ErrorContext = {
        tenantId: message.tenantId,
        customerPhone: message.from,
        messageId: message.messageId,
        action: 'handleMessage',
      };

      const fallback = this.errorHandler.handleError(err, errorContext);

      // Track error metrics
      if (this.config.enableAnalytics) {
        await this.trackMetrics({
          tenantId: message.tenantId,
          timestamp: new Date(),
          messageId: message.messageId || '',
          customerPhone: message.from,
          direction: 'inbound',
          messageType: message.messageType || 'text',
          processingTimeMs: Date.now() - startTime,
          success: false,
          errorMessage: err.message,
        });
      }

      return fallback.message;
    }
  }

  /**
   * Processa mensagem de carrinho
   */
  async handleCartCommand(
    message: IncomingMessage,
    command: string,
  ): Promise<MessageHandlerResponse> {
    try {
      const cart = await this.cartService.getOrCreateCart(message.tenantId, message.from);

      // Parse comando
      const parsed = this.parseCartCommand(command);

      switch (parsed.action) {
        case 'add': {
          const product = await this.productsService.findByName(message.tenantId, parsed.productName);
          if (!product) {
            return `Não encontrei "${parsed.productName}". Quer ver o cardápio?`;
          }

          await this.cartService.addItem({
            tenantId: message.tenantId,
            customerPhone: message.from,
            produtoId: product.id,
            produtoName: product.nome,
            quantity: parsed.quantity || 1,
            unitPrice: Number(product.preco),
          });

          const updatedCart = await this.cartService.getOrCreateCart(message.tenantId, message.from);
          return this.cartService.generateSummary(updatedCart);
        }

        case 'remove': {
          const cartItems = cart.items;
          const item = cartItems.find(
            (i) => i.produto_name.toLowerCase().includes(parsed.productName.toLowerCase()),
          );

          if (!item) {
            return `Não encontrei "${parsed.productName}" no carrinho.`;
          }

          const updatedCart = await this.cartService.removeItem(cart.id, item.produto_id);
          return this.cartService.generateSummary(updatedCart);
        }

        case 'update': {
          const cartItems = cart.items;
          const item = cartItems.find(
            (i) => i.produto_name.toLowerCase().includes(parsed.productName.toLowerCase()),
          );

          if (!item) {
            return `Não encontrei "${parsed.productName}" no carrinho.`;
          }

          const updatedCart = await this.cartService.updateItem(
            cart.id,
            item.produto_id,
            parsed.quantity,
          );
          return this.cartService.generateSummary(updatedCart);
        }

        case 'clear': {
          await this.cartService.clearCart(cart.id);
          return '🛒 Carrinho esvaziado! Quando quiser adicionar algo, é só me dizer.';
        }

        case 'show': {
          return this.cartService.generateSummary(cart);
        }

        case 'confirm': {
          if (cart.items.length === 0) {
            return '🛒 Seu carrinho está vazio! Adicione itens primeiro.';
          }

          // TODO: Implementar lógica de confirmação de pedido
          return 'Ótimo! Vou precisar de algumas informações para finalizar seu pedido...\n\n' +
            'Primeiro, me diga seu nome:';
        }

        default:
          return this.cartService.generateSummary(cart);
      }
    } catch (error) {
      const err = error instanceof Error ? error : new Error(String(error));
      const context: ErrorContext = {
        tenantId: message.tenantId,
        customerPhone: message.from,
        action: 'cartCommand',
      };
      const fallback = this.errorHandler.handleError(err, context);
      return fallback.message;
    }
  }

  /**
   * Envia mensagem de saída (para o provider)
   */
  async sendMessage(outgoing: OutgoingMessage): Promise<void> {
    // TODO: Integrar com WhatsApp provider (Twilio/Evolution API)
    this.logger.log('Sending message', { to: outgoing.to, type: outgoing.messageType });
  }

  // ============== MÉTODOS PRIVADOS ==============

  private validateMessage(message: IncomingMessage): void {
    if (!message.from) {
      throw new Error('Missing required field: from');
    }
    if (!message.body && !message.mediaUrl) {
      throw new Error('Missing required field: body or mediaUrl');
    }
    if (!message.tenantId) {
      throw new Error('Missing required field: tenantId');
    }
  }

  private async buildRoutingContext(
    message: IncomingMessage,
    conversation: any,
    botConfig: BotConfig,
  ): Promise<any> {
    // Buscar mensagens recentes da conversa
    const recentMessages: string[] = [];
    // TODO: Implementar busca de mensagens recentes

    // Buscar carrinho atual se enabled
    let cartSummary: string | undefined;
    if (this.config.enableCart) {
      const cart = await this.cartService.getOrCreateCart(message.tenantId, message.from);
      if (cart.items.length > 0) {
        cartSummary = `${cart.items.length} itens no carrinho (R$ ${cart.total_amount.toFixed(2)})`;
      }
    }

    return {
      message: message.body,
      botConfig,
      catalogSummary: [], // TODO: buscar do ProductsService
      currentState: conversation?.context?.state || null,
      recentMessages,
      customerName: conversation?.customer_name || null,
      pendingOrderSummary: cartSummary,
    };
  }

  private async generateStateResponse(
    message: IncomingMessage,
    state: string,
    botConfig: BotConfig,
    conversation: any,
  ): Promise<string> {
    // TODO: Implementar respostas específicas por estado
    return 'Entendi! Pode me dar mais detalhes?';
  }

  private async generateDefaultResponse(
    message: IncomingMessage,
    decision: RouterDecision,
    botConfig: BotConfig,
  ): Promise<string> {
    // TODO: Implementar resposta padrão baseada no decision.action
    return 'Entendi. Como posso ajudar?';
  }

  private parseCartCommand(command: string): {
    action: 'add' | 'remove' | 'update' | 'clear' | 'show' | 'confirm' | 'unknown';
    productName?: string;
    quantity?: number;
  } {
    const lower = command.toLowerCase().trim();

    // Comandos de ação direta
    if (lower === 'carrinho' || lower === 'ver carrinho' || lower === 'mostrar carrinho') {
      return { action: 'show' };
    }

    if (lower === 'limpar' || lower === 'esvaziar' || lower === 'limpar carrinho') {
      return { action: 'clear' };
    }

    if (lower === 'confirmar' || lower === 'finalizar' || lower === 'pedir') {
      return { action: 'confirm' };
    }

    // Comandos com parâmetros
    const addMatch = lower.match(/^(?:adicionar|add|addicionar)\s+(.+?)(?:\s+(\d+))?$/);
    if (addMatch) {
      return {
        action: 'add',
        productName: addMatch[1].trim(),
        quantity: addMatch[2] ? parseInt(addMatch[2], 10) : 1,
      };
    }

    const removeMatch = lower.match(/^(?:remover|delete|tirar)\s+(.+)$/);
    if (removeMatch) {
      return { action: 'remove', productName: removeMatch[1].trim() };
    }

    const updateMatch = lower.match(/^(?:quantidade|qtd|update)\s+(.+?)\s+(\d+)$/);
    if (updateMatch) {
      return {
        action: 'update',
        productName: updateMatch[1].trim(),
        quantity: parseInt(updateMatch[2], 10),
      };
    }

    // Detectar intenção de adicionar pelo contexto
    // "manda 2 brigadeiros", "quero 3", etc
    const intentMatch = lower.match(/^(?:manda|quero|preciso|pedir)\s+(\d+)?\s*(.+)$/);
    if (intentMatch) {
      return {
        action: 'add',
        productName: intentMatch[2].trim(),
        quantity: intentMatch[1] ? parseInt(intentMatch[1], 10) : 1,
      };
    }

    return { action: 'unknown' };
  }

  private async trackMetrics(metrics: MessageMetrics): Promise<void> {
    try {
      await this.analytics.trackMessage(metrics);
    } catch (error) {
      this.logger.warn('Failed to track metrics', { error });
    }
  }
}